APP_NAME="SMKN 8 Pandeglang"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# XAMPP: arahkan ke folder public, contoh:
APP_URL=http://localhost/websekolah_v1/public
# Akses dari HP (WiFi sama): `composer serve:lan` lalu sementara set:
# APP_URL=http://ALAMAT_IP_KOMPUTER:8000
# (Lihat IP: macOS: ipconfig getifaddr en0  —  Windows: ipconfig)
#
# Tes lewat internet (ngrok):
# 1) Terminal: php artisan serve (atau: composer run serve:lan  —  port 8000)
# 2) Terminal lain: ngrok http 8000
# 3) Salin URL https://xxxx.ngrok-free.app (atau .ngrok.io) lalu set:
#    APP_URL=https://xxxx.ngrok-free.app
#    TRUSTED_PROXIES=*
# 4) php artisan config:clear
# Hapus TRUSTED_PROXIES (atau kosongkan) bila tidak pakai ngrok.
TRUSTED_PROXIES=

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Gunakan MySQL (disarankan produksi) — lihat database/schema_mysql.sql
# Hosting (cPanel): salin deploy/env.hosting.example → .env di server, isi DB_* dari cPanel → MySQL Databases.
# Host di shared hosting biasanya localhost (bukan 127.0.0.1).
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=smkn8_pandeglang
DB_USERNAME=root
DB_PASSWORD=

# Atau SQLite: DB_CONNECTION=sqlite, DB_DATABASE=database/database.sqlite, dan buat file database/database.sqlite
# DB_CONNECTION=sqlite
# DB_DATABASE="/absolute/path/to/laravel-app/database/database.sqlite"

# file = butuh write ke storage/; di XAMPP sering gagal (Apache vs pemilik file). gunakan cookie untuk lokal
SESSION_DRIVER=cookie
SESSION_ENCRYPT=true
SESSION_LIFETIME=480
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
