# Salin ke .env di server hosting (~/repositories/websekolahku_v1/.env)
# Jangan commit file .env — berisi kredensial database.

APP_NAME="SMKN 8 Pandeglang"
APP_ENV=production
APP_KEY=                    # generate: php artisan key:generate
APP_DEBUG=false
APP_URL=https://smkn8pandeglang.sch.id

APP_LOCALE=id
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=error

# --- Database MySQL (cPanel) ---
# Buat database & user di cPanel → MySQL Databases, lalu isi di bawah.
# Host biasanya localhost (bukan 127.0.0.1) di shared hosting.
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=cpaneluser_smkn8
DB_USERNAME=cpaneluser_smkn8
DB_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT

SESSION_DRIVER=database
SESSION_ENCRYPT=true
SESSION_LIFETIME=480

FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

MAIL_MAILER=smtp
MAIL_HOST=mail.smkn8pandeglang.sch.id
MAIL_PORT=587
MAIL_USERNAME=noreply@smkn8pandeglang.sch.id
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@smkn8pandeglang.sch.id"
MAIL_FROM_NAME="${APP_NAME}"
